# Dev-only Doubao credentials (M11 settings store 上线后改由 UI 输入)
#
# 复制本文件为 .env（gitignored）然后填入实际值。
# 新版控制台用 single key 模式：只需 DOUBAO_API_KEY，外加 DOUBAO_RESOURCE_ID。
# 旧版控制台用 dual-header 模式：DOUBAO_APP_KEY + DOUBAO_ACCESS_KEY + DOUBAO_RESOURCE_ID。

# 新版控制台 X-Api-Key（UUID 形式）
DOUBAO_API_KEY=

# 资源 ID。流式 v2 小时版用 volc.seedasr.sauc.duration；v1 用 volc.bigasr.sauc.duration
DOUBAO_RESOURCE_ID=volc.seedasr.sauc.duration

# Endpoint 变体：bigmodel_async (推荐) / bigmodel / bigmodel_nostream
DOUBAO_ENDPOINT_KEY=bigmodel_async

# 仅旧版控制台需要：
# DOUBAO_APP_KEY=
# DOUBAO_ACCESS_KEY=
